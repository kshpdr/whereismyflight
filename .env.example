# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# AviationStack API key (https://aviationstack.com - free tier: 100 req/month)
# Leave blank to use built-in demo mode with realistic mock data.
AVIATIONSTACK_API_KEY=

# Public HTTPS URL where this server is reachable (required for Mini App).
WEBAPP_BASE_URL=https://whereismyflight.uk

# Port for the built-in web server (Caddy reverse-proxies to this)
PORT=8080
