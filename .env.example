# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Flight data provider — set ONE of these (FlightAware takes priority).
# Leave both blank to use built-in demo mode with realistic mock data.

# FlightAware AeroAPI (https://www.flightaware.com/aeroapi/ — free: ~$0 up to 2k lookups/mo)
FLIGHTAWARE_API_KEY=

# AviationStack (https://aviationstack.com — free tier: 100 req/month)
AVIATIONSTACK_API_KEY=

# Public HTTPS URL where this server is reachable (required for Mini App).
WEBAPP_BASE_URL=https://whereismyflight.uk

# Port for the built-in web server (Caddy reverse-proxies to this)
PORT=8080
